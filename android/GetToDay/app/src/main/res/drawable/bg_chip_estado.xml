<?xml version="1.0" encoding="utf-8"?>
<!--
    Fondo del chip de estado de la cita.
    La forma es un rectángulo con esquinas muy redondeadas
    para dar aspecto de pastilla/etiqueta.
    El color de fondo se cambia desde Java según el estado.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Color por defecto: naranja suave (estado pendiente) -->
    <solid android:color="@color/estado_pendiente_bg"/>

    <!-- Esquinas redondeadas tipo pastilla -->
    <corners android:radius="20dp"/>

</shape>