<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/GetToDay.Card"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Nombre del servicio -->
        <TextView
            android:id="@+id/tvNombreServicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del servicio"
            android:textSize="16sp"
            android:textColor="@color/azul_oscuro"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <!-- Descripción -->
        <TextView
            android:id="@+id/tvDescripcionServicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descripción del servicio"
            android:textSize="13sp"
            android:textColor="@color/texto_secundario"
            android:layout_marginBottom="8dp"/>

        <!-- Línea divisora -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/borde_campo"
            android:layout_marginBottom="8dp"/>

        <!-- Fila: precio y duración fija -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Precio -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Precio: "
                    android:textSize="13sp"
                    android:textColor="@color/texto_secundario"/>

                <TextView
                    android:id="@+id/tvPrecioServicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—€"
                    android:textSize="13sp"
                    android:textColor="@color/texto_primario"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- Duración fija -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Duración: "
                    android:textSize="13sp"
                    android:textColor="@color/texto_secundario"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 hora"
                    android:textSize="13sp"
                    android:textColor="@color/texto_primario"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Línea divisora -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/borde_campo"
            android:layout_marginBottom="12dp"/>

        <!-- Botones de acción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnEliminarServicio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Eliminar"
                style="@style/GetToDay.Button.Secondary"
                android:textColor="@color/estado_cancelada"
                android:strokeColor="@color/estado_cancelada"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnEditarServicio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Editar"
                style="@style/GetToDay.Button.Secondary"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>