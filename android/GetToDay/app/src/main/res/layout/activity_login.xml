<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_pantalla"
    android:fillViewport="true">

    <!--
        ScrollView: envuelve todo el contenido para que si el teclado
        aparece, el usuario pueda hacer scroll y ver todos los campos.
        fillViewport="true": aunque el contenido sea pequeño, ocupa
        toda la pantalla.
    -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="28dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- ── LOGO ────────────────────────────── -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/gettoday_logo"
            android:contentDescription="Logo GetToDay"
            android:scaleType="fitCenter"
            android:layout_marginBottom="8dp"/>

        <!-- ── NOMBRE DE LA APP ────────────────── -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GetToDay"
            android:textSize="26sp"
            android:textColor="@color/azul_oscuro"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>


        <!-- ── CARD DEL FORMULARIO ─────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/GetToDay.Card"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Título del formulario -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Iniciar sesión"
                    android:textSize="18sp"
                    android:textColor="@color/azul_oscuro"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"/>

                <!-- ── CAMPO EMAIL ─────────────── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/GetToDay.Input"
                    android:hint="Correo electrónico"
                    app:endIconMode="clear_text"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:maxLines="1"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── CAMPO CONTRASEÑA ────────── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/GetToDay.Input"
                    android:hint="Contraseña"
                    app:endIconMode="password_toggle"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:maxLines="1"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── ¿OLVIDASTE CONTRASEÑA? ──── -->
                <Button
                    android:id="@+id/btnForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="¿Olvidaste tu contraseña?"
                    style="@style/GetToDay.Button.Text"
                    android:textSize="12sp"
                    android:layout_marginBottom="20dp"/>

                <!-- ── BOTÓN ENTRAR ────────────── -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Entrar"
                    style="@style/GetToDay.Button.Primary"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── FOOTER: IR A REGISTRAR USUARIO ───────────── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿No tienes cuenta? "
                android:textSize="14sp"
                android:textColor="@color/texto_secundario"/>

            <Button
                android:id="@+id/btnGoToRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Regístrate"
                style="@style/GetToDay.Button.Text"
                android:textSize="14sp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>