<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_pantalla"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="80dp">

        <!-- ── FILA: TÍTULO + BOTÓN AÑADIR ────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mis servicios"
                android:textSize="22sp"
                android:textColor="@color/azul_oscuro"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnAnadirServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Añadir"
                style="@style/GetToDay.Button.Primary"
                android:paddingHorizontal="16dp"/>

        </LinearLayout>

        <!-- ── CARD: FORMULARIO AÑADIR/EDITAR ─── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFormServicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/GetToDay.Card"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Título dinámico -->
                <TextView
                    android:id="@+id/tvTituloFormServicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nuevo servicio"
                    android:textSize="16sp"
                    android:textColor="@color/azul_oscuro"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"/>

                <!-- Nombre del servicio -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutNombreServicio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/GetToDay.Input"
                    android:hint="Nombre del servicio"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNombreServicio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:imeOptions="actionNext"
                        android:maxLines="1"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Descripción del servicio -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutDescripcionServicio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/GetToDay.Input"
                    android:hint="Descripción"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDescripcionServicio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:maxLines="4"
                        android:gravity="top"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Precio -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutPrecioServicio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/GetToDay.Input"
                    android:hint="Precio (€)"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPrecioServicio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:imeOptions="actionDone"
                        android:maxLines="1"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Duración fija — no editable -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/borde_campo"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Duración"
                        android:textSize="14sp"
                        android:textColor="@color/texto_secundario"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 hora (fija)"
                        android:textSize="14sp"
                        android:textColor="@color/texto_primario"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Botones guardar y cancelar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnCancelarServicio"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Cancelar"
                        style="@style/GetToDay.Button.Secondary"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnGuardarServicio"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Guardar"
                        style="@style/GetToDay.Button.Primary"
                        android:layout_marginStart="8dp"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── ESTADO VACÍO ───────────────────── -->
        <TextView
            android:id="@+id/tvSinServicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No tienes servicios añadidos aún"
            android:textSize="14sp"
            android:textColor="@color/texto_secundario"
            android:gravity="center"
            android:paddingVertical="32dp"
            android:visibility="gone"/>

        <!-- ── LISTA DE SERVICIOS ─────────────── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerServicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>
</ScrollView>