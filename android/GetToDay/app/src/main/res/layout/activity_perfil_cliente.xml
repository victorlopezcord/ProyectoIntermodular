<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_pantalla"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="80dp">

        <!-- ── TÍTULO ─────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mi perfil"
            android:textSize="22sp"
            android:textColor="@color/azul_oscuro"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- ── CARD: DATOS EN MODO VISTA ─────── -->
        <!--
            Visible por defecto.
            Se oculta cuando el usuario pulsa "Editar".
        -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVista"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/GetToDay.Card"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Fila título + botón editar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Datos personales"
                        android:textSize="16sp"
                        android:textColor="@color/azul_oscuro"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnEditar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Editar"
                        style="@style/GetToDay.Button.Secondary"
                        android:paddingHorizontal="16dp"/>

                </LinearLayout>

                <!-- Nombre -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nombre"
                        android:textSize="13sp"
                        android:textColor="@color/texto_secundario"/>

                    <TextView
                        android:id="@+id/tvNombrePerfil"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="—"
                        android:textSize="14sp"
                        android:textColor="@color/texto_primario"/>

                </LinearLayout>

                <!-- Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Email"
                        android:textSize="13sp"
                        android:textColor="@color/texto_secundario"/>

                    <TextView
                        android:id="@+id/tvEmailPerfil"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="—"
                        android:textSize="14sp"
                        android:textColor="@color/texto_primario"/>

                </LinearLayout>

                <!-- Teléfono -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Teléfono"
                        android:textSize="13sp"
                        android:textColor="@color/texto_secundario"/>

                    <TextView
                        android:id="@+id/tvTelefonoPerfil"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="—"
                        android:textSize="14sp"
                        android:textColor="@color/texto_primario"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── CARD: DATOS EN MODO EDICIÓN ────── -->
        <!--
            Oculta por defecto.
            Se muestra cuando el usuario pulsa "Editar".
        -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEdicion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/GetToDay.Card"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Editar datos"
                    android:textSize="16sp"
                    android:textColor="@color/azul_oscuro"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"/>

                <!-- Campo nombre editable -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutNombreEditar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/GetToDay.Input"
                    android:hint="Nombre completo"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNombreEditar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:imeOptions="actionNext"
                        android:maxLines="1"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo teléfono editable -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutTelefonoEditar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/GetToDay.Input"
                    android:hint="Teléfono"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTelefonoEditar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:imeOptions="actionDone"
                        android:maxLines="1"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botones guardar y cancelar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnCancelar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Cancelar"
                        style="@style/GetToDay.Button.Secondary"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnGuardar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Guardar"
                        style="@style/GetToDay.Button.Primary"
                        android:layout_marginStart="8dp"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── CARD: CERRAR SESIÓN ────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/GetToDay.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sesión"
                    android:textSize="16sp"
                    android:textColor="@color/azul_oscuro"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnCerrarSesion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cerrar sesión"
                    style="@style/GetToDay.Button.Secondary"
                    android:backgroundTint="@color/estado_cancelada"
                    android:textColor="@color/blanco"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>